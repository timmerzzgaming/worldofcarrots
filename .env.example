# Optional — only used for the decorative home page map background.
# Game pages use an inline light style (no API key needed).
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_api_key

# Supabase — required for user accounts and credits.
# Leave blank to run in guest-only mode (all features work, no persistence).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — required for admin operations (creating test accounts).
# Find this in Supabase Dashboard → Settings → API → service_role key.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=
